# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Get from: https://supabase.com/dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── 0G Network / Compute ─────────────────────────────────────
# Get from: https://pc.0g.ai/dashboard/api-keys
ROUTER_API_KEY=your-router-api-key-here

# ── 0G Storage SDK ───────────────────────────────────────────
# Galileo Testnet indexer (storage node discovery)
INDEXER_RPC=https://indexer-storage-turbo-testnet.0g.ai
# 0G Storage KV node endpoint (single node for testnet)
KV_NODE_URL=http://3.101.147.150:6789
# 0G FixedPriceFlow contract on Galileo Testnet
FLOW_CONTRACT_ADDRESS=0xbD2C3F0E65eDF5582141C35969d66e34629cC768
# Fixed bytes32 stream ID namespace for Gochi KV data
GOCHI_STREAM_ID=0x676f636869000000000000000000000000000000000000000000000000000001

# ── Smart Contract ────────────────────────────────────────────
# Deployed Gochi.sol address (set after: npm run contract:deploy:0g-galileo)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x

# ── Smart Contract Deployment (Hardhat) ──────────────────────
# Get from: MetaMask → Account Details → Show Private Key
# Guide: https://support.metamask.io/hc/en-us/articles/360015289632-How-to-export-an-account-s-private-key
# IMPORTANT: Use a burner wallet! Do not use your primary wallet containing funds.
PRIVATE_KEY=your-metamask-private-key-here

# ── OpenAI ───────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Optional ─────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── WalletConnect ────────────────────────────────────────────
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
