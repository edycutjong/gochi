{
  "name": "gochi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage",
    "contract:compile": "hardhat compile",
    "contract:node": "hardhat node",
    "contract:deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "contract:deploy:0g": "hardhat run scripts/deploy.ts --network 0g-mainnet",
    "contract:deploy:testnet": "node scripts/deploy.mjs testnet",
    "contract:deploy:mainnet": "node scripts/deploy.mjs mainnet"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.9",
    "@metamask/connect-evm": "^1.3.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.49.2",
    "wagmi": "^3.6.15"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@openzeppelin/contracts": "^5.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "hardhat": "^3.4.5",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "overrides": {
    "wagmi": "$wagmi",
    "axios": "^1.7.9",
    "cookie": "^0.7.2",
    "elliptic": "^6.6.1",
    "postcss": "^8.5.3",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.4",
    "undici": "^6.23.1"
  }
}
